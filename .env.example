# Non-secret local configuration for Quizz.
# Copy this file to .env before running Docker or local tooling.
#
# Do NOT put passwords, tokens, API keys, or database secrets here.
# Database password is managed through Docker Compose secrets.

QUIZZ_HTTP_PORT=8081

QUIZZ_DEFAULT_ADMIN_EMAIL=admin@example.com
QUIZZ_DEFAULT_ADMIN_FULL_NAME=Admin User

POSTGRES_DB=quizz
POSTGRES_USER=quizz
